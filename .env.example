# =============================================================================
# Environment template. Copy to `.env` and fill in real values.
# NEVER commit `.env`. Every variable here MUST be declared, typed, and
# validated in the config layer (src/config) — see rules/17-configuration-and-environment.md.
# =============================================================================

# --- Application -------------------------------------------------------------
NODE_ENV=development                 # development | test | production
PORT=3000
APP_NAME=UltimateNatives
GLOBAL_PREFIX=api

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info                       # error | warn | info | debug

# --- Security / Auth ---------------------------------------------------------
# Development placeholder only; production startup rejects placeholder secrets.
JWT_SECRET=change-me-min-32-characters-long-secret
JWT_EXPIRES_IN_SECONDS=1800
CORS_ORIGIN=http://localhost:3000    # comma-separated allowed origins

# --- Rate limiting -----------------------------------------------------------
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100

# --- Feature flags -----------------------------------------------------------
ENABLE_SWAGGER=true

# --- Database (PostgreSQL + TypeORM) -----------------------------------------
# Provide EITHER a single connection URL, OR the discrete fields below.
# Discrete fields fall back to development-safe defaults when unset
# (localhost:5432, user "postgres", database "ultimate_natives").
# NEVER commit real credentials — these are commented placeholders only.
DATABASE_URL=postgres://user:password@localhost:5432/ultimate_natives
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=natives
DB_PASSWORD=natives_dev_password
DB_NAME=ultimate_natives
# Connection pool bounds (min <= max).
DB_POOL_MIN=2
DB_POOL_MAX=10
# Timeouts in milliseconds.
DB_CONNECT_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=15000
# TLS to the database. MUST be true in production (startup fails otherwise).
DB_SSL=false
# Verbose SQL logging (keep false outside local debugging).
DB_LOGGING=false

# --- Identity: token lifetimes & login throttling ----------------------------
# All TTLs are in SECONDS. Opaque tokens (invite, refresh, reset) are stored as
# hashes only; plaintext tokens are delivered out-of-band and never persisted.
IDENTITY_REFRESH_TOKEN_TTL_SECONDS=1209600     # 14 days
IDENTITY_INVITATION_TTL_SECONDS=604800         # 7 days
IDENTITY_PASSWORD_RESET_TTL_SECONDS=3600       # 1 hour
IDENTITY_MAX_FAILED_LOGIN_ATTEMPTS=5
IDENTITY_FAILED_LOGIN_WINDOW_SECONDS=900        # 15 minutes
IDENTITY_ACCOUNT_LOCKOUT_SECONDS=900            # 15 minutes

# --- Cache / queue (optional) ------------------------------------------------
# REDIS_URL=redis://localhost:6379
