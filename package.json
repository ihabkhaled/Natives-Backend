{
  "name": "natives-backend",
  "version": "1.0.0",
  "description": "Ultimate Natives backend — NestJS + Fastify + TypeORM + PostgreSQL API for the Ultimate Natives Frisbee team, built on the IronNest strict clean-architecture operating system (custom ESLint rules, strict TypeScript, SDLC governance, and an AI-agent knowledge base).",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0"
  },
  "overrides": {
    "@nestjs/platform-fastify": {
      "fastify": "$fastify"
    }
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --concurrency 2",
    "lint:fix": "eslint --concurrency 2 --fix",
    "typecheck": "tsc --pretty --noEmit --incremental false",
    "test": "vitest run",
    "test:unit": "vitest run --exclude test/app.e2e-spec.ts",
    "test:e2e": "vitest run test/**/*.e2e-spec.ts",
    "test:watch": "vitest",
    "test:debug": "vitest --inspect-brk run --pool=forks --poolOptions.forks.singleFork=true",
    "test:coverage": "vitest run --coverage",
    "typeorm": "node -r dotenv/config -r ts-node/register/transpile-only -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/database/cli-data-source.ts src/database/migrations/Migration",
    "migration:run": "npm run typeorm -- migration:run -d src/database/cli-data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/cli-data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/database/cli-data-source.ts",
    "db:ensure": "node -r dotenv/config -r ts-node/register/transpile-only -r tsconfig-paths/register src/database/ensure-database.cli.ts",
    "seed:admin": "node -r dotenv/config -r ts-node/register/transpile-only -r tsconfig-paths/register src/database/seeds/seed-admin.cli.ts",
    "db:setup": "npm run db:ensure && npm run migration:run && npm run seed:admin",
    "contract:generate": "node -r dotenv/config -r ts-node/register/transpile-only -r tsconfig-paths/register tools/openapi/generate-openapi.ts",
    "contract:check": "npm run contract:generate -- --check",
    "contract:compatibility": "node -r ts-node/register/transpile-only tools/openapi/check-openapi-compatibility.ts",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run knowledge:check && npm run knowledge:verify",
    "knowledge:build": "node tools/knowledge/build-manifests.mjs && node tools/knowledge/build-summaries.mjs",
    "knowledge:check": "node tools/knowledge/build-hashes.mjs --check",
    "knowledge:context": "node tools/knowledge/resolve-context.mjs",
    "knowledge:benchmark": "node tools/knowledge/benchmark.mjs",
    "knowledge:verify": "node tools/knowledge/verify.mjs",
    "security:audit": "npm audit --audit-level=high",
    "security:scan": "trivy fs --scanners vuln,secret,misconfig --include-dev-deps --skip-dirs node_modules,dist,coverage --exit-code 1 --severity HIGH,CRITICAL .",
    "security:scan:full": "trivy fs --scanners vuln,secret,misconfig --include-dev-deps --skip-dirs node_modules,dist,coverage .",
    "deps:check": "npm-check-updates",
    "deps:upgrade": "npm-check-updates -u && npm install",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/static": "^10.1.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.10.0",
    "nestjs-pino": "^4.6.1",
    "pg": "8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "typeorm": "1.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "@typescript-eslint/parser": "^8.64.0",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-unicorn": "^72.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-check-updates": "^22.2.9",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "@swc/core@1.15.43": true,
    "bcrypt@6.0.0": true,
    "unrs-resolver@1.12.2": true,
    "@scarf/scarf": false
  }
}
