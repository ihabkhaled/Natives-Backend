{
  "name": "nestjs-strict-workspace",
  "version": "1.0.0",
  "description": "Production-grade strict NestJS backend workspace: layered architecture enforced by a custom ESLint plugin, full type-safety, and an AI operating system (rules, skills, agents, memory, context).",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "brace-expansion": "5.0.6"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build -p tsconfig.build.json",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --concurrency 4",
    "lint:fix": "eslint --concurrency 4 --fix",
    "typecheck": "tsgo --pretty --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:debug": "vitest --inspect-brk run --pool=forks --poolOptions.forks.singleFork=true",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@fastify/static": "9.1.3",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "2.1.1",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/platform-fastify": "11.1.27",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/throttler": "6.5.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.22",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.40",
    "@types/cookie-parser": "1.4.10",
    "@types/node": "25.9.2",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@typescript/native-preview": "7.0.0-dev.20260608.1",
    "@vitest/coverage-istanbul": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "brace-expansion": "5.0.6",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.1.0",
    "eslint-plugin-unicorn": "68.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "rimraf": "6.0.1",
    "supertest": "7.0.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  }
}
